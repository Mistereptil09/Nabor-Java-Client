<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tech.nabor.ui.IncidentsController"
            styleClass="content-area">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="screen-toolbar">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16"/>
            </padding>
            <Label fx:id="screenTitle" styleClass="screen-title"/>
            <Label fx:id="filterLabel"/>
            <ComboBox fx:id="statusFilter"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="newButton" onAction="#onNew" styleClass="accent-button"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="table">
            <columns>
                <TableColumn fx:id="titleCol" prefWidth="260"/>
                <TableColumn fx:id="severityCol" prefWidth="110"/>
                <TableColumn fx:id="statusCol" prefWidth="130"/>
                <TableColumn fx:id="createdCol" prefWidth="170"/>
            </columns>
        </TableView>
    </center>

    <right>
        <VBox fx:id="detailPane" spacing="10" prefWidth="300" styleClass="detail-pane">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <Label fx:id="detailTitle" wrapText="true" styleClass="detail-title"/>
            <Label fx:id="detailMeta" wrapText="true" styleClass="detail-meta"/>
            <Label fx:id="detailDescription" wrapText="true"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="assignButton" onAction="#onAssign" maxWidth="Infinity"/>
            <Button fx:id="resolveButton" onAction="#onResolve" maxWidth="Infinity"/>
        </VBox>
    </right>

</BorderPane>
