<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Écran Synchronisation & conflits (§7.3) : état de synchro + résolution manuelle. -->
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tech.nabor.ui.SyncController"
            styleClass="content-area">

    <top>
        <VBox styleClass="screen-toolbar">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16"/>
            </padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label fx:id="screenTitle" styleClass="screen-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="simulateButton" onAction="#onSimulate"/>
                <Button fx:id="syncButton" onAction="#onSync" styleClass="accent-button"/>
            </HBox>
            <Label fx:id="statusLabel" styleClass="detail-meta"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="12" right="16" bottom="12" left="16"/>
            </padding>
            <Label fx:id="conflictsTitle" styleClass="detail-title"/>
            <TableView fx:id="table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="entityCol" prefWidth="150"/>
                    <TableColumn fx:id="fieldCol" prefWidth="120"/>
                    <TableColumn fx:id="localCol" prefWidth="160"/>
                    <TableColumn fx:id="remoteCol" prefWidth="160"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label fx:id="resolveHint" styleClass="detail-meta"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="keepLocalButton" onAction="#onKeepLocal"/>
                <Button fx:id="keepRemoteButton" onAction="#onKeepRemote" styleClass="accent-button"/>
            </HBox>
        </VBox>
    </center>

</BorderPane>
