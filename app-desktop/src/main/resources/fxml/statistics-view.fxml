<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tech.nabor.ui.StatisticsController"
            styleClass="content-area">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="screen-toolbar">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16"/>
            </padding>
            <Label fx:id="screenTitle" styleClass="screen-title"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <!-- Cartes KPI -->
            <HBox fx:id="kpiRow" spacing="14">
                <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="kpiIncidentsValue" styleClass="kpi-value"/>
                    <Label fx:id="kpiIncidentsLabel" styleClass="kpi-label"/>
                </VBox>
                <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="kpiEventsValue" styleClass="kpi-value"/>
                    <Label fx:id="kpiEventsLabel" styleClass="kpi-label"/>
                </VBox>
                <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="kpiRegistrationsValue" styleClass="kpi-value"/>
                    <Label fx:id="kpiRegistrationsLabel" styleClass="kpi-label"/>
                </VBox>
            </HBox>

            <FlowPane fx:id="chartsBox" hgap="18" vgap="18"/>
        </VBox>
    </center>

</BorderPane>
